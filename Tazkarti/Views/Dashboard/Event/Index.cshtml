@model IEnumerable<EventVM>
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var locale = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = locale.StartsWith("ar");
}
<div class="p-4">
    <h2 class="text-xl font-bold mb-4">@Localizer["Events"]</h2>

    <!-- Button to Add Event -->
    <div class="mb-4">
        <a asp-action="Create"
           class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded transition-colors">
            @Localizer["Create New Event"]
        </a>
    </div>

    <!-- Events Table -->
    <table class="min-w-full bg-white shadow-md rounded overflow-hidden">
        <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
                <th class="py-3 px-4 text-left font-bold text-gray-700">@Localizer["Name"]</th>
                <th class="py-3 px-4 text-left font-bold text-gray-700">@Localizer["Place"]</th>
                <th class="py-3 px-4 text-left font-bold text-gray-700">@Localizer["Date"]</th>
                <th class="py-3 px-4 text-left font-bold text-gray-700">@Localizer["Action"]</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="py-3 px-4 text-sm text-gray-600">@(isArabic ? item.NameAr : item.Name)</td>
                    <td class="py-3 px-4 text-sm text-gray-600">@(isArabic ? item.placeAr : item.place)</td>
                    <td class="py-3 px-4 text-sm text-gray-600">@(item.Time?.ToString("g"))</td>
                    <td class="py-3 px-4 flex gap-2">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="bg-blue-400 text-white px-3 py-1 rounded text-sm hover:bg-blue-500 transition-colors">@Localizer["Edit"]</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="POST" onsubmit="return confirm('@Localizer["Are you sure?"]');">
                            <button type="submit" class="bg-red-500 text-white px-3 py-1 rounded text-sm hover:bg-red-600 transition-colors">@Localizer["Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios@1.1.2/dist/axios.min.js"></script>
