@model TicketVM
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}
<div class="max-w-md mt-6 mx-auto p-6 bg-white rounded-lg shadow-md">
    <h2 class="text-2xl font-bold text-center mb-4">@Localizer["Details"] @Localizer["Ticket"] - @Model.EventName</h2>

    <div class="space-y-4">
        <div>
            <label class="block text-gray-700 font-bold mb-1">@Localizer["Id"] :</label>
            <input type="text" asp-for="Id" class="w-full bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 text-gray-600 focus:outline-none" readonly />
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-1">@Localizer["Event Name :"]</label>
            <input type="text" asp-for="EventName" class="w-full bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 text-gray-600 focus:outline-none" readonly />
        </div>

        <div class="flex items-center gap-2 py-2">
            <input type="checkbox" asp-for="Valid" class="rounded border-gray-300 text-blue-600 focus:ring-blue-500" disabled />
            <label class="text-gray-700 font-bold">@Localizer["Valid"]</label>
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-1">@Localizer["Email"] :</label>
            <input type="text" asp-for="Email" class="w-full bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 text-gray-600 focus:outline-none" readonly />
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-1">@Localizer["PhoneNum"] :</label>
            <input type="text" asp-for="PhoneNumber" class="w-full bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 text-gray-600 focus:outline-none" readonly />
        </div>

        <div>
            <label class="block text-gray-700 font-bold mb-1">@Localizer["Name"] :</label>
            <input type="text" asp-for="Name" class="w-full bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 text-gray-600 focus:outline-none" readonly />
        </div>

        <div class="text-center pt-4">
            <a asp-action="Index" class="inline-block bg-blue-500 hover:bg-blue-600 text-white font-bold py-2 px-8 rounded-lg transition-colors">
                @Localizer["Back to List"]
            </a>
        </div>
    </div>
</div>
