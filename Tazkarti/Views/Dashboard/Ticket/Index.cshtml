@model IEnumerable<TicketVM>
@{
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var locale = System.Globalization.CultureInfo.CurrentUICulture.Name;
    var isArabic = locale.StartsWith("ar");
}
<div class="p-4">
    <h2 class="text-xl font-bold mb-4">@Localizer["tickets"]</h2>
    <form class="my-5" asp-action="Index">
        <div class="flex gap-4 max-w-2xl">
            <input placeholder="@Localizer["Search..."]" name="SearchValue" class="flex-1 appearance-none block bg-gray-200 border border-gray-200 rounded-lg px-3 py-2 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-gray-300" />
            <input type="submit" value="@Localizer["Search"]" class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-6 rounded-lg cursor-pointer transition-colors" />
        </div>
    </form>

    <!-- Tickets Table -->
    <table class="min-w-full bg-white shadow-md rounded overflow-hidden">
        <thead class="bg-gray-100 dark:bg-gray-800">
            <tr>
                <th class="py-3 px-4 font-bold">@Localizer["Id"]</th>
                <th class="py-3 px-4 font-bold">@Localizer["Events"]</th>
                <th class="py-3 px-4 font-bold">@Localizer["Valid"]</th>
                <th class="py-3 px-4 font-bold">@Localizer["Name"]</th>
                <th class="py-3 px-4 font-bold">@Localizer["Email"]</th>
                <th class="py-3 px-4 font-bold">@Localizer["PhoneNum"]</th>
                <th class="py-3 px-4 font-bold">@Localizer["Action"]</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
            @foreach (var item in Model)
            {
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="py-3 px-4 text-center text-sm text-gray-600">@item.Id</td>
                    <td class="py-3 px-4 text-center text-sm text-gray-600">@(isArabic ? item.EventNameAr : item.EventName)</td>
                    <td class="py-3 px-4 text-center text-sm text-gray-600">
                        <span class="px-2 py-1 rounded-full text-xs @(item.Valid ? "bg-green-100 text-green-800" : "bg-red-100 text-red-800")">
                            @(item.Valid ? Localizer["Valid"].Value : "N/A")
                        </span>
                    </td>
                    <td class="py-3 px-4 text-center text-sm text-gray-600 font-medium">@item.Name</td>
                    <td class="py-3 px-4 text-center text-sm text-gray-600">@item.Email</td>
                    <td class="py-3 px-4 text-center text-sm text-gray-600">@item.PhoneNumber</td>
                    <td class="py-3 px-4 flex gap-2 justify-center items-center ">
                        <a asp-action="Details" asp-route-id="@item.Id" class="bg-blue-400 text-white px-3 py-1.5 rounded text-sm hover:bg-blue-500 transition-colors">@Localizer["Details"]</a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="POST" onsubmit="return confirm('@Localizer["Are you sure?"]');">
                            <button type="submit" class="bg-red-500 text-white px-3 py-1.5 rounded text-sm hover:bg-red-600 transition-colors">@Localizer["Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script src="https://cdn.jsdelivr.net/npm/axios@1.1.2/dist/axios.min.js"></script>
