@model EventVM
@{
    ViewData["Title"] = "Event Details";
    var isArabic = System.Globalization.CultureInfo.CurrentUICulture.Name.StartsWith("ar");
}

<div class="container mx-auto px-4 sm:px-6 lg:px-8 mt-12 mb-24 animated fadeIn">
    <!-- Back Navigation -->
    <div class="mb-8">
        <a asp-action="Index" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
            @Localizer["Back to Events"]
        </a>
    </div>

    <div class="max-w-5xl mx-auto bg-white dark:bg-gray-800 rounded-3xl shadow-xl shadow-blue-900/5 border border-gray-100 dark:border-gray-700 overflow-hidden lg:flex relative transition-colors">
        <!-- Event Image Section -->
        <div class="relative lg:w-1/2 h-80 lg:h-auto overflow-hidden group">
            <img src="~/Files/Images/@Model.ImageName" alt="@(isArabic? Model.NameAr: Model.Name)" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-in-out" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
            
            <div class="absolute bottom-0 left-0 p-8 text-white w-full">
                <div class="bg-blue-600/90 backdrop-blur-sm text-white text-sm font-bold px-3 py-1 rounded-full inline-block mb-4 shadow-sm">
                    @Model.NoOfTickets @Localizer["left"]
                </div>
                <h1 class="text-3xl md:text-4xl font-extrabold mb-3 leading-tight">@(isArabic? Model.NameAr: Model.Name)</h1>
                <div class="flex items-center text-blue-100 mb-2">
                    <svg class="w-5 h-5 mr-2 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                    <span class="font-medium text-lg">@(isArabic? Model.placeAr: Model.place)</span>
                </div>
                <div class="flex items-center text-blue-100">
                    <svg class="w-5 h-5 mr-2 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    <span class="font-medium text-lg">@Model.Time</span>
                </div>
            </div>
        </div>

        <!-- Booking Form Section -->
        <div class="lg:w-1/2 p-8 md:p-12 flex flex-col justify-center bg-gray-50/50 dark:bg-gray-900/50 transition-colors">
            @if (!string.IsNullOrEmpty(Model.Info))
            {
                <div class="mb-8">
                    <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-3 flex items-center">
                        <svg class="w-5 h-5 mr-2 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        @Localizer["About Event"]
                    </h3>
                    <p class="text-gray-600 dark:text-gray-400 leading-relaxed bg-white dark:bg-gray-800 p-4 rounded-2xl border border-gray-100 dark:border-gray-700 shadow-sm">
                        @(isArabic? Model.InfoAr: Model.Info)
                    </p>
                </div>
            }

            <div class="mb-10">
                <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white tracking-tight mb-2">@Localizer["Secure"]</h2>
                <p class="text-gray-500 dark:text-gray-400">@Localizer["Complete"]</p>
            </div>

            <div class="bg-blue-50 dark:bg-blue-900/20 bg-opacity-50 border border-blue-100 dark:border-blue-800 rounded-2xl p-6 mb-8 flex justify-between items-center shadow-sm">
                <div>
                    <p class="text-sm font-medium text-blue-600 dark:text-blue-400 mb-1 uppercase tracking-wider">@Localizer["Ticket Price"]</p>
                    <p class="text-3xl font-bold text-gray-900 dark:text-white">$@Model.Price<span class="text-lg text-gray-500 dark:text-gray-400 font-normal">@Localizer["person"]</span></p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-blue-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path></svg>
                </div>
            </div>

            <form asp-action="TicketsDetails" method="get" id="bookingForm" class="space-y-6 flex-grow flex flex-col">
                <input hidden name="id" value="@Model.Id" />
                
                <div>
                    <label for="guest" class="block text-sm font-bold text-gray-700 dark:text-gray-300 mb-2">@Localizer["Number of Guests"]</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                        </div>
                        <input type="number" name="numOfTicket" id="guest" placeholder="@Localizer["Enter"]" min="1" max="@Model.NoOfTickets" required
                               class="w-full pl-12 pr-4 py-4 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl text-gray-900 dark:text-white font-medium focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-shadow shadow-sm shadow-black/5"
                               oninput="updateTotal()" />
                    </div>
                </div>

                <div class="mt-auto pt-6 border-t border-gray-200 dark:border-gray-700">
                    <div class="flex justify-between items-center mb-6">
                        <span class="text-gray-600 dark:text-gray-400 font-medium text-lg">@Localizer["Total Amount"]</span>
                        <span id="totalPrice" class="text-3xl font-extrabold text-blue-700 dark:text-blue-500 transition-all duration-300">$0.00</span>
                    </div>

                    <button type="submit" class="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-bold py-4 px-8 rounded-xl transition-all duration-300 shadow-lg shadow-blue-600/30 transform hover:-translate-y-0.5 focus:ring-4 focus:ring-blue-200 flex items-center justify-center gap-3">
                        <span>@Localizer["Confirm Booking"]</span>
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            updateTotal();
        });

        function updateTotal() {
            const guestInput = document.getElementById("guest");
            const count = parseInt(guestInput.value) || 0;
            const price = parseFloat('@Model.Price.ToString(System.Globalization.CultureInfo.InvariantCulture)');
            const total = count * price;
            
            const totalElement = document.getElementById("totalPrice");
            totalElement.textContent = '$' + total.toFixed(2);
            
            // Add a subtle bump animation when total changes by toggling a class
            totalElement.style.transform = "scale(1.1)";
            setTimeout(() => {
                totalElement.style.transform = "scale(1)";
            }, 150);
        }
    </script>
}
